  padding: 0.75rem;
  border-radius: 8px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s;
  text-align: center;
  width: 100%;
}

.addBlockBtn:hover {
  border-color: #388087;
  color: #388087;
  background-color: #f0fdfa;
}

