  transition: border-color 0.18s ease, box-shadow 0.18s ease, background-color 0.18s ease;
  resize: vertical;
}

.fieldInput:focus,
.fieldTextarea:focus {
  outline: none;
  border-color: var(--primary-teal);
  background: #ffffff;
  box-shadow: 0 0 0 3px rgba(56, 128, 135, 0.12);
}

.fieldInput::placeholder,
.fieldTextarea::placeholder {
  color: #9ca3af;
}

.fieldInputError {
  border-color: #ef4444 !important;
  background: #fef2f2 !important;
}

.fieldErrorText {
  font-size: 0.78rem;
  color: #ef4444;
  font-weight: 500;
}

/* --- Template section --- */
.templateSectionHeader {
  text-align: center;
  margin-bottom: 2.2rem;
}

.templateSectionHeader h3 {
  margin: 0 0 0.35rem 0;
  font-size: 1.5rem;
  font-weight: 800;
  color: #111827;
}

.templateSectionHeader p {
  margin: 0;
  color: #6b7280;
  font-size: 0.95rem;
}

.templateSectionHeader strong {
  color: var(--primary-teal);
}

/* --- Template grid: 2 cols mobile, 3 cols laptop, 4 cols big desktop --- */
/* --- Template grid: 2 cols mobile, 3 cols laptop, 4 cols big desktop --- */
/* --- Template grid: 1 col mobile, 2 cols tablet, 3 cols desktop --- 
   Capped at 3 columns on purpose -- more columns means smaller cards,
   and the whole point is for each resume to be big enough to actually
   read the layout at a glance. */
.templateGrid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 2rem;
  max-width: 560px;
  margin: 0 auto;
}

@media (min-width: 640px) {
  .templateGrid {
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    max-width: 1000px;
  }
}

@media (min-width: 1100px) {
  .templateGrid {
    grid-template-columns: repeat(3, 1fr);
    gap: 2.75rem;
    max-width: 1650px;
  }
}
.templateCard {
  display: flex;
  flex-direction: column;
  gap: 0.9rem;
}

.templateImageWrap {
  position: relative;
  width: 100%;
  aspect-ratio: 3 / 4.1;
  border-radius: 14px;
  overflow: hidden;
  background: #f3f4f6;
  border: 1px solid #eaecee;
  box-shadow: 0 4px 14px rgba(17, 24, 39, 0.06);
  transition: box-shadow 0.25s ease, transform 0.25s ease;
}

.templateImageWrap:hover {
  transform: translateY(-4px);
  box-shadow: 0 16px 34px rgba(17, 24, 39, 0.14);
}

.templateImage {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: top center;
  display: block;
  transition: transform 0.4s ease;
}

.templateImageWrap:hover .templateImage {
  transform: scale(1.045);
}

/* Overlay that slides up from the bottom on hover */
.templateOverlay {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding-bottom: 1.6rem;
  background: linear-gradient(to top, rgba(20, 50, 52, 0.82) 0%, rgba(20, 50, 52, 0.35) 45%, rgba(20, 50, 52, 0) 75%);
  opacity: 0;
  transform: translateY(8px);
  transition: opacity 0.25s ease, transform 0.25s ease;
}

.templateImageWrap:hover .templateOverlay {
  opacity: 1;
  transform: translateY(0);
}

.useTemplateBtn {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  background: #ffffff;
  color: var(--primary-teal);
  border: none;
  padding: 0.65rem 1.3rem;
  border-radius: 999px;
  font-size: 0.85rem;
  font-weight: 700;
  cursor: pointer;
  box-shadow: 0 6px 18px rgba(0, 0, 0, 0.25);
  transition: background-color 0.18s ease, color 0.18s ease, transform 0.15s ease;
}

.useTemplateBtn:hover:not(:disabled) {
  background: var(--primary-teal);
  color: #ffffff;
  transform: translateY(-1px);
}

.useTemplateBtn:disabled {
  opacity: 0.6;
  cursor: not-allowed;
}

.btnSpinner {
  width: 13px;
  height: 13px;
  border: 2px solid rgba(56, 128, 135, 0.3);
  border-top-color: var(--primary-teal);
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.templateLabel {
  display: flex;
  flex-direction: column;
  gap: 2px;
  padding: 0 0.15rem;
}

.templateName {
  font-weight: 700;
  font-size: 0.98rem;
  color: #111827;
}

.templateDescription {
  font-size: 0.8rem;
  color: #6b7280;
  line-height: 1.35;
}

@media (max-width: 720px) {
  .detailsGrid {
    grid-template-columns: 1fr;
  }
  .detailsCard {
    padding: 1.4rem;
  }
}
