      />
      {/* Arrowhead */}
      <path 
        d="M 85,35 L 105,50 L 85,65" 
        stroke="#388087" 
        strokeWidth="4" 
        strokeLinecap="round" 
        strokeLinejoin="round" 
        className={styles.arrowHead}
      />
    </svg>
  </div>
);

const Home = () => {
