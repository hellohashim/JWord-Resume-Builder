<file path="src/pages/Account/Account.module.css">
.accountContainer {
  max-width: 900px;
  margin: 2rem auto;
  padding: 0 1rem;
}

.subtext {
  color: #6b7280;
  margin-bottom: 1.5rem;
  font-size: 0.95rem;
}

.uploadArea {
  border: 2px dashed #d1d5db;
  padding: 2.5rem;
  text-align: center;
  border-radius: 8px;
  background-color: #f9fafb;
  transition: border-color 0.2s;
}

.uploadArea:hover {
  border-color: #388087;
}

.fileInput {
  margin: 0 auto;
}

.parsingText {
  color: #388087;
  font-weight: 600;
  margin-top: 1rem;
  text-align: center;
  animation: pulse 1.5s infinite;
}

@keyframes pulse {
  0% { opacity: 0.6; }
  50% { opacity: 1; }
  100% { opacity: 0.6; }
}

/* Form Layout */
.profileForm {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  margin-top: 1.5rem;
}

.formSection {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}

.sectionTitle {
  font-size: 1.2rem;
  color: #111827;
  margin: 0;
  border-left: 4px solid #388087;
  padding-left: 0.75rem;
}

.divider {
  border: none;
  border-top: 1px solid #e5e7eb;
  margin: 1.5rem 0;
}

.inputRow {
  display: flex;
  gap: 1.5rem;
}

@media (max-width: 768px) {
  .inputRow {
    flex-direction: column;
    gap: 1rem;
  }
}

.inputGroup {
  display: flex;
  flex-direction: column;
  flex: 1;
  gap: 0.4rem;
}

.inputGroup label {
  font-size: 0.9rem;
  font-weight: 500;
  color: #374151;
}

.inputGroup input,
.inputGroup textarea {
  padding: 0.75rem;
  border: 1px solid #d1d5db;
  border-radius: 6px;
  font-family: inherit;
  font-size: 0.95rem;
  transition: border-color 0.2s, box-shadow 0.2s;
}

.inputGroup input:focus,
.inputGroup textarea:focus {
  outline: none;
  border-color: #388087;
  box-shadow: 0 0 0 3px rgba(56, 128, 135, 0.1);
}

.checkboxGroup {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  margin-top: 0.5rem;
}

.checkboxGroup label {
  font-size: 0.9rem;
  color: #374151;
  cursor: pointer;
}

/* Skills Pill UI */
.skillsWrapper {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.skillsList {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
}

.skillPill {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  background-color: #f3f4f6;
  color: #1f2937;
  padding: 0.4rem 0.8rem;
  border-radius: 9999px; /* This makes the fully curved border */
  border: 1px solid #e5e7eb;
  font-size: 0.9rem;
  font-weight: 500;
}

.removeSkillBtn {
  background: none;
  border: none;
  color: #6b7280;
  font-size: 1.1rem;
  line-height: 1;
  cursor: pointer;
  padding: 0;
  margin-left: 2px;
  transition: color 0.2s;
}

.removeSkillBtn:hover {
  color: #ef4444; /* Red on hover */
}

.addSkillGroup {
  display: flex;
  gap: 0.5rem;
  max-width: 400px;
}

.addSkillGroup input {
  flex: 1;
  padding: 0.6rem 0.75rem;
  border: 1px solid #d1d5db;
  border-radius: 6px;
  font-size: 0.9rem;
}

.addSkillGroup input:focus {
  outline: none;
  border-color: #388087;
}

.addSkillBtn {
  background-color: #f3f4f6;
  color: #374151;
  border: 1px solid #d1d5db;
  padding: 0 1rem;
  border-radius: 6px;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s;
}

.addSkillBtn:hover {
  background-color: #e5e7eb;
  color: #111827;
}

/* Dynamic Blocks (Education, Experience, etc.) */
.dynamicBlock {
  position: relative;
  background-color: #f8fafc;
  border: 1px solid #e2e8f0;
  border-radius: 8px;
  padding: 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.deleteBlockBtn {
  position: absolute;
  top: 10px;
  right: 15px;
  background: none;
  border: none;
  color: #94a3b8;
  font-size: 1.5rem;
  cursor: pointer;
  line-height: 1;
  transition: color 0.2s;
